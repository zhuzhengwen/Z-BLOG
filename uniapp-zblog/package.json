    "build:app":  "cross-env NODE_ENV=production   UNI_PLATFORM=app-plus  vue-cli-service uni-build"
  },
  "dependencies": {
    "vuex": "^3.6.2"
  },
  "devDependencies": {
    "@dcloudio/types":               "*",
    "@dcloudio/uni-app":             "3.0.0-3080620230817001",
    "@dcloudio/uni-cli-shared":      "3.0.0-3080620230817001",
    "@dcloudio/uni-stacktracey":     "3.0.0-3080620230817001",
    "@dcloudio/vue-cli-plugin-uni":  "3.0.0-3080620230817001",
    "@vue/cli-plugin-babel":         "~5.0.0",
    "@vue/cli-service":              "~5.0.0",
    "cross-env":                     "^7.0.3",
    "sass":                          "^1.39.0",
    "sass-loader":                   "^12.0.0"
  }
}
